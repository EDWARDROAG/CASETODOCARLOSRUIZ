# Copiar a .env en esta misma carpeta (raíz del asociado Casetodo).

PORT=8080
N8N_WEBHOOK_URL=https://tu-instancia-n8n/webhook/casetodo-lead-modal

# Chat RAG (phase "chat"). El dev-server reenvía POST /api/n8n-rag aquí.
# Magnus casetodo-web-chat-v2: si ponés Production …/webhook/…, dev-server 1.6+ usa Test al arrancar
# salvo N8N_RAG_PREFER_PRODUCTION=1 (cuando el workflow ya está Active en Production).
N8N_RAG_WEBHOOK_URL=https://n8n.platform.magnusai.co/webhook/casetodo-web-chat-v2

# GitHub Pages (https://edwardroag.github.io/CASETODOCARLOSRUIZ/):
# el navegador no lee este .env. Pegá la misma URL en
# frontend/n8n-webhook.config.js → variable N8N_WEBHOOK_URL_PRODUCTION
