### AL ###
# Template for AL projects for Dynamics 365 Business Central

# VS Code
.vscode/

# AL folders
.alcache/
.alpackages/
.snapshots/
.output/

# Extension files
*.app

# RAD
rad.json

# Translation
*.g.xlf

# License
*.flf

# Test results
TestResults.xml

# Environment
.env
.env.*
!.env.example
!backend/.env.example

# Logs
*.log
logs/

# Node (IMPORTANTE)
node_modules/
package-lock.json
scripts/

# Solo local — no publicar en GitHub
backend/
frontend_antiguo/
deploy-vitrina/
docs/
especificaciones cliente/

# Legacy raíz (sitio HTML antiguo; la vitrina es frontend-angular/)
/index.html
/config.js
/n8n-webhook.config.js
/site-check.js
/dev-server.mjs
/cloudflare-worker-rag-cors-proxy.js
/CONFIGURACION-INDEPENDIENTE.txt
/package.json
/package-lock.json

# OS files
.DS_Store
Thumbs.db

# Temp files
*.tmp
*.temp

# Git
.gitignore.lock

# Coverage / testing
coverage/

# Optional
dist/
build/

# n8n — exportaciones de workflows (no versionar; n8n-webhook.config.js sí: GitHub Pages lo necesita en el repo)
**/n8n-workflow*.json
**/n8n-*-workflow*.json

# Memoria operativa privada (no subir)
PROJECT_MEMORY.md
PROJECT_RULES_MEMORY.md
contexto.md
TRAZABILIDAD_INTEGRIDAD_SEGURIDAD.md
PROJECT_STRUCTURE.txt

