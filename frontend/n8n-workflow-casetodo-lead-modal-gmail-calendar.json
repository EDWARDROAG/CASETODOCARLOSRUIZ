    {
      "parameters": {
        "jsCode": "// Borrador estructurado sin API externa (sustituir por nodo Gemini si usas el otro workflow).\nconst j = $input.first().json;\nconst msg = String(j.mensaje || '').trim();\nconst intent = String(j.intent || '');\nconst nombre = String(j.nombre || '');\nconst lines = [\n  '--- Solicitud (borrador) ---',\n  `Tipo: ${intent || 'вЂ”'}`,\n  `Cliente: ${nombre || 'вЂ”'}`,\n  `TelГ©fono: ${String(j.telefono || 'вЂ”')}`,\n  '',\n  'Detalle ordenado:',\n  ''\n];\nif (!msg) {\n  lines.push('(El cliente no escribiГі detalle en el mensaje.)');\n} else {\n  const chunks = msg\n    .split(/[.\\n;]+/)\n    .map((s) => s.trim())\n    .filter(Boolean);\n  chunks.forEach((c, i) => lines.push(`${i + 1}. ${c}`));\n}\nlines.push('', '--- Fin borrador ---');\nreturn [{ json: { ...j, structuredMensaje: lines.join('\\n') } }];"
      },
      "id": "code-structure-gcal-001",
      "name": "Estructura borrador",
