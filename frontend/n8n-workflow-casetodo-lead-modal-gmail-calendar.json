    {
      "parameters": {
        "jsCode": "const j = $input.first().json;\nconst summary = [\n  'NUEVA SOLICITUD (confirmada)',\n  `Asociado: ${j.associateSlug || 'вЂ”'}`,\n  `Intent: ${j.intent || 'вЂ”'}`,\n  `Nombre: ${j.nombre || 'вЂ”'}`,\n  `Tel: ${j.telefono || 'вЂ”'}`,\n  `Email: ${j.email || 'вЂ”'}`,\n  `Origen mensaje: ${j.mensajeSource || 'вЂ”'}`,\n  '',\n  '--- Texto organizado ---',\n  String(j.structuredMensaje || 'вЂ”'),\n  '',\n  '--- Mensaje original ---',\n  String(j.mensajeOriginal || 'вЂ”')\n].join('\\n');\n\n// Bloque de agenda: maГ±ana a las 10:00, 30 min (ajusta en n8n si necesitas otra regla)\nconst start = new Date();\nstart.setDate(start.getDate() + 1);\nstart.setHours(10, 0, 0, 0);\nconst end = new Date(start);\nend.setMinutes(end.getMinutes() + 30);\n\nreturn [\n  {\n    json: {\n      ...j,\n      _teamSummary: summary,\n      _receivedAt: new Date().toISOString(),\n      _eventStart: start.toISOString(),\n      _eventEnd: end.toISOString(),\n      _eventTitle: 'Seguimiento lead web вЂ” ' + String(j.nombre || 'Casetodo').slice(0, 80)\n    }\n  }\n];"
      },
