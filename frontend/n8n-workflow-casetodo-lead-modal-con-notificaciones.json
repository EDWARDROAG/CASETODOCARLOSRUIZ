      "parameters": {
        "jsCode": "// Unifica cuerpo: n8n a veces entrega el JSON en .body y otras en la raíz.\nconst item = $input.first().json;\nconst body = item.body;\nconst payload =\n  body !== undefined && body !== null && typeof body === 'object' && !Array.isArray(body)\n    ? { ...body }\n    : { ...item };\nreturn [{ json: payload }];"
      },
