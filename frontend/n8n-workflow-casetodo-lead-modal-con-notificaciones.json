    {
      "parameters": {
        "jsCode": "// Datos finales confirmados por el cliente.\nconst j = $input.first().json;\nconst summary = [\n  'NUEVA SOLICITUD (confirmada)',\n  `Asociado: ${j.associateSlug || '—'}`,\n  `Intent: ${j.intent || '—'}`,\n  `Nombre: ${j.nombre || '—'}`,\n  `Tel: ${j.telefono || '—'}`,\n  `Email: ${j.email || '—'}`,\n  `Origen mensaje: ${j.mensajeSource || '—'}`,\n  '',\n  '--- Texto organizado ---',\n  String(j.structuredMensaje || '—'),\n  '',\n  '--- Mensaje original ---',\n  String(j.mensajeOriginal || '—')\n].join('\\n');\nreturn [{ json: { ...j, _teamSummary: summary, _receivedAt: new Date().toISOString() } }];"
      },
