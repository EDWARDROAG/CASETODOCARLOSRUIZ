          "renameFallbackOutput": "otro"
        }
      },
      "id": "switch-phase-001",
      "name": "Switch por phase",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3.2,
      "position": [820, 400]
    },
    {
      "parameters": {
        "jsCode": "// Borrador estructurado SIN API externa (sustituir por OpenAI si quieres IA real).\nconst j = $input.first().json;\nconst msg = String(j.mensaje || '').trim();\nconst intent = String(j.intent || '');\nconst nombre = String(j.nombre || '');\nconst lines = [\n  '--- Solicitud (borrador) ---',\n  `Tipo: ${intent || '—'}`,\n  `Cliente: ${nombre || '—'}`,\n  `Teléfono: ${String(j.telefono || '—')}`,\n  '',\n  'Detalle ordenado:',\n  ''\n];\nif (!msg) {\n  lines.push('(El cliente no escribió detalle en el mensaje.)');\n} else {\n  const chunks = msg\n    .split(/[.\\n;]+/)\n    .map((s) => s.trim())\n    .filter(Boolean);\n  chunks.forEach((c, i) => lines.push(`${i + 1}. ${c}`));\n}\nlines.push('', '--- Fin borrador ---');\nreturn [{ json: { ...j, structuredMensaje: lines.join('\\n') } }];"
      },
      "id": "code-structure-001",
      "name": "Estructura borrador",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1080, 260]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ { structuredMensaje: $json.structuredMensaje } }}",
        "options": {
          "responseCode": 200
        }
      },
      "id": "respond-structure-001",
      "name": "Responder structure",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [1320, 260]
    },
    {
      "parameters": {
        "jsCode": "// Datos finales + texto de ejemplo para el front (no envía correos).\nconst j = $input.first().json;\nconst nombre = String(j.nombre || 'Cliente').trim();\nconst email = String(j.email || '').trim();\nconst hasEmail = email.length > 0 && email.includes('@');\nconst fragment = String(j.structuredMensaje || j.mensajeOriginal || '')\n  .trim()\n  .slice(0, 280);\nconst clientMessage = hasEmail\n  ? `[Prueba] Recibimos tu solicitud. En producción enviaríamos un correo de confirmación a ${email}.`\n  : '[Prueba] Recibimos tu solicitud. Sin correo no habría email de confirmación al cliente.';\nreturn [\n  {\n    json: {\n      ...j,\n      _testClientMessage: clientMessage,\n      _testPreview: {\n        nombre: nombre || '—',\n        email: hasEmail ? email : null,\n        resumenCorto: fragment || '(sin texto)'\n      }\n    }\n  }\n];"
      },
      "id": "code-submit-mock-001",
      "name": "Prueba — respuesta mock",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1120, 520]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ { ok: true, received: true, message: $json._testClientMessage, preview: $json._testPreview } }}",
        "options": {
          "responseCode": 200
        }
      },
      "id": "respond-submit-001",
      "name": "Responder submit",
      "type": "n8n-nodes-base.respondToWebhook",
